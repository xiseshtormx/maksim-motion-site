---
interface Props {
  mode?: "full" | "compact" | "mark";
  tone?: "light" | "dark" | "blue";
  class?: string;
  label?: string;
}

const {
  mode = "full",
  tone = "light",
  class: className = "",
  label = "KAIROS — Motion Design / Video Editing",
} = Astro.props;

const ticks = Array.from({ length: 15 });
---

<div
  class:list={["kairosLogo", `kairosLogo--${mode}`, `kairosLogo--${tone}`, className]}
  role="img"
  aria-label={label}
>
  <span class="kairosSymbol" aria-hidden="true">
    <i class="markStem"></i>
    <i class="markArm markArmTop"></i>
    <i class="markArm markArmBottom"></i>
    <span class="markTimeline">
      {ticks.map((_, index) => (
        <i
          style={`--tick-height: ${index < 8 ? 0.28 + index * 0.045 : Math.max(0.22, 0.72 - (index - 8) * 0.075)}em; --tick-width: ${index < 4 ? 0.54 : index > 8 ? 0.14 : 0.25}em`}
        ></i>
      ))}
    </span>
    <i class="markCore"></i>
  </span>

  {mode !== "mark" && <span class="logoDivider" aria-hidden="true"></span>}

  {mode !== "mark" && (
    <span class="wordmark">
      <strong>KAIROS</strong>
      <small>MOTION DESIGN / VIDEO EDITING</small>
    </span>
  )}
</div>

<style>
  .kairosLogo {
    --logo-color: #f3efe5;
    --logo-opposite: #0b0d0f;
    display: inline-flex;
    align-items: center;
    gap: 2.5em;
    color: var(--logo-color);
    font-size: 10px;
    line-height: 1;
  }

  .kairosLogo--dark {
    --logo-color: #0b0d0f;
    --logo-opposite: #f3efe5;
  }

  .kairosLogo--blue {
    --logo-color: #0b3e72;
    --logo-opposite: #f3efe5;
  }

  .kairosSymbol {
    position: relative;
    flex: 0 0 auto;
    width: 9em;
    height: 6.4em;
    isolation: isolate;
  }

  .markStem,
  .markArm,
  .markCore {
    position: absolute;
    display: block;
    background: currentColor;
  }

  .markStem {
    top: 0.55em;
    bottom: 0.55em;
    left: 2.55em;
    width: 1.55em;
  }

  .markArmTop {
    top: 0.55em;
    left: 3.28em;
    width: 4.55em;
    height: 2.8em;
    clip-path: polygon(28% 100%, 0 100%, 72% 0, 100% 0);
  }

  .markArmBottom {
    top: 3.05em;
    left: 3.22em;
    width: 4.7em;
    height: 2.8em;
    clip-path: polygon(0 0, 27% 0, 100% 100%, 70% 100%);
  }

  .markTimeline {
    position: absolute;
    z-index: 4;
    top: 2.83em;
    left: 0;
    width: 9em;
    height: 0.76em;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .markTimeline i {
    width: var(--tick-width);
    height: var(--tick-height);
    background: currentColor;
  }

  .markCore {
    z-index: 5;
    top: 2.76em;
    left: 3.08em;
    width: 1.4em;
    height: 0.9em;
    background: var(--logo-opposite);
    clip-path: polygon(0 0, 100% 50%, 0 100%);
  }

  .logoDivider {
    width: 1px;
    height: 6.3em;
    background: currentColor;
    opacity: 0.45;
  }

  .wordmark {
    display: grid;
    gap: 1.15em;
    white-space: nowrap;
  }

  .wordmark strong {
    font-family: "Arial", "Helvetica Neue", sans-serif;
    font-size: 4.35em;
    font-weight: 400;
    line-height: 0.78;
    letter-spacing: 0.24em;
  }

  .wordmark small {
    font-size: 0.92em;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.54em;
  }

  .kairosLogo--compact {
    gap: 1.35em;
    font-size: 5.4px;
  }

  .kairosLogo--compact .logoDivider {
    height: 5.3em;
  }

  .kairosLogo--compact .wordmark {
    gap: 0.9em;
  }

  .kairosLogo--compact .wordmark strong {
    font-size: 3.9em;
  }

  .kairosLogo--compact .wordmark small {
    font-size: 0.72em;
  }

  .kairosLogo--mark {
    font-size: inherit;
  }
</style>
