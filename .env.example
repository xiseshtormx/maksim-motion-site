# Создайте эти переменные в Netlify: Project configuration → Environment variables.
# Не добавляйте реальный API-ключ в Git.
RESEND_API_KEY=re_xxxxxxxxx
KAIROS_LEADS_TO=max@example.com

# Пока домен не подключён, Resend разрешает тестовую отправку через onboarding@resend.dev
# только на email владельца аккаунта Resend. После проверки домена замените адрес отправителя.
KAIROS_MAIL_FROM=KAIROS <onboarding@resend.dev>
